portant;font-weight:700;text-decoration:none!important}.pdmshell-footer-button:hover,.pdmshell-footer-button:focus{background:#1d4ed8}.pdmshell-footer-bottom{display:grid;justify-items:center;gap:10px;padding:34px 24px 28px;background:var(--footer-bottom);color:var(--footer-text);border-top:0;text-align:center}.pdmshell-footer-partner-logo{display:block;width:86px;height:auto;margin:0 0 8px}.pdmshell-footer-bottom nav{display:flex;flex-wrap:wrap;justify-content:center;gap:12px 22px}.pdmshell-footer-bottom p{margin:0;color:var(--footer-muted)}@media(max-width:1199.98px){.pdmshell-footer-main{grid-template-columns:1fr;gap:26px;padding:34px 24px 38px}.pdmshell-footer-column h2{font-size:14px}.pdmshell-footer-logo-image{width:min(280px,100%)}}\u003c/style\u003e\u003cdiv class=\u0027pdmshell-footer\u0027\u003e\u003cdiv class=\u0027pdmshell-footer-main\u0027\u003e\u003csection class=\u0027pdmshell-footer-column\u0027\u003e\u003cimg class=\u0027pdmshell-footer-logo-image\u0027 src=\u0027https://docs.bluebyte.biz/images/large_logo.png\u0027 alt=\u0027Blue Byte Systems Inc.\u0027\u003e\u003cp\u003e170-422 Richards St\u003c/p\u003e\u003cp\u003eVancouver\u003c/p\u003e\u003cp\u003eBC V6B 2Z4, Canada\u003c/p\u003e\u003cp\u003eBusiness Hours: 9 AM PST - 5 PM PST\u003c/p\u003e\u003cp\u003ePhone: (778)-200-2012\u003c/p\u003e\u003c/section\u003e\u003csection class=\u0027pdmshell-footer-column\u0027\u003e\u003ch2\u003ePRODUCTS\u003c/h2\u003e\u003cp\u003e\u003ca href=\u0027https://pdmpublisher.com\u0027\u003ePDMPublisher (SOLIDWORKS 3D)\u003c/a\u003e\u003c/p\u003e\u003cp\u003e\u003ca href=\u0027https://pdmpublisher.com\u0027\u003ePDMPublisher (SOLIDWORKS Professional Only)\u003c/a\u003e\u003c/p\u003e\u003cp\u003e\u003ca href=\u0027https://pdmshell.bluebyte.biz\u0027\u003ePDMShell (SOLIDWORKS Professional Only)\u003c/a\u003e\u003c/p\u003e\u003ch2\u003eHELP CENTER\u003c/h2\u003e\u003cp\u003e\u003ca href=\u0027https://pdmshell.bluebyte.biz/src/index.html\u0027\u003ePDMShell documentation